    public static void main(String[] args) throws Exception {

        // Bandeja do sistema
        if (!SystemTray.isSupported()) {
            System.out.println("SystemTray não suportado.");
            return;
        }

        // Ícone
        BufferedImage image = new BufferedImage(16, 16, BufferedImage.TYPE_INT_RGB);
        Graphics2D g = image.createGraphics();
        g.setColor(Color.CYAN);
        g.fillOval(0, 0, 16, 16);
        g.dispose();

        // Menu
        PopupMenu menu = new PopupMenu();
        MenuItem sair = new MenuItem("Sair");
        sair.addActionListener(e -> System.exit(0));
        menu.add(sair);

        TrayIcon trayIcon = new TrayIcon(image, "Jarvis", menu);
        trayIcon.setImageAutoSize(true);
        SystemTray.getSystemTray().add(trayIcon);

        falar("Jarvis iniciado.");
        trayIcon.displayMessage("Jarvis", "Ouvindo...", TrayIcon.MessageType.INFO);
        
        //modelo
        Model model = new Model("C:/programacao/JARVIS/JARVIS/model/vosk-model-small-pt-0.3");
        Recognizer rec = new Recognizer(model, 16000);
        
        //microfone
        TargetDataLine mic = AudioSystem.getTargetDataLine(
            new AudioFormat(16000, 16, 1, true, false)
        );

        mic.open();
        mic.start();

        byte[] buffer = new byte[4096];
        
        //loop infinito
        while (true) {

            int bytesRead = mic.read(buffer, 0, buffer.length);

            if (rec.acceptWaveForm(buffer, bytesRead)) {

                String resultado = rec.getResult();

                String texto = resultado
                    .replace("{\"text\":\"", "")
                    .replace("\"}", "")
                    .trim()
                    .toLowerCase();

                System.out.println("Reconhecido: " + texto);

                if (!texto.isEmpty()) {
                    executar(texto);
                }
            }

            Thread.sleep(20);
        }
    }
