    public static void falar(String texto) throws Exception {
        String script = "Add-Type -AssemblyName System.Speech; " +
            "$s = New-Object System.Speech.Synthesis.SpeechSynthesizer; " +
            "$s.SelectVoice('Microsoft Maria Desktop'); " +
            "$s.Speak('" + texto + "');";
        new ProcessBuilder("powershell", "-Command", script).start().waitFor();
    }

    public static String perguntarIA(String pergunta) throws Exception {
        URL url = new URL("http://localhost:11434/api/generate");
        HttpURLConnection con = (HttpURLConnection) url.openConnection();
        con.setRequestMethod("POST");
        con.setRequestProperty("Content-Type", "application/json");
        con.setDoOutput(true);
        con.setConnectTimeout(5000);
        con.setReadTimeout(60000);

        String body = "{\"model\":\"llama3.2:1b\",\"prompt\":\"Responda em portugues: " + pergunta + "\",\"stream\":false}";

        try (OutputStream os = con.getOutputStream()) {
            os.write(body.getBytes("utf-8"));
        }

        StringBuilder resposta = new StringBuilder();
        try (BufferedReader br = new BufferedReader(
                new InputStreamReader(con.getInputStream(), "utf-8"))) {
            String linha;
            while ((linha = br.readLine()) != null) {
                resposta.append(linha);
            }
        }

        // Extrai só o campo "response" do JSON
        String json = resposta.toString();
        int inicio = json.indexOf("\"response\":\"") + 12;
        int fim = json.indexOf("\"", inicio);
        return json.substring(inicio, fim).replace("\\n", " ").trim();
    }

