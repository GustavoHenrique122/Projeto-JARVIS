import whisper
import sounddevice as sd
import numpy as np
import sys

sys.stdout.reconfigure(encoding='utf-8')

model = whisper.load_model("base")
print("Whisper pronto.", flush=True)

COMANDOS = ["youtube", "google", "calculadora", "esporte", "carro",
            "assassinos", "valores", "conversar", "parede", "desligar",
            "reiniciar", "cancelar", "pergunta", "responde", "parar", "jarvis", "chat"]

SAMPLE_RATE = 16000
LIMIAR_VOZ = 0.02       # volume minimo para considerar voz
SEGUNDOS_GRAVACAO = 4   # segundos de gravacao apos detectar voz

print("Ouvindo...", flush=True)

while True:
    # Fica escutando ate detectar voz
    trecho = sd.rec(int(0.5 * SAMPLE_RATE), samplerate=SAMPLE_RATE, channels=1, dtype='float32')
    sd.wait()
    volume = np.abs(trecho).mean()

    if volume < LIMIAR_VOZ:
        continue

    # Detectou voz, grava o comando completo
    print("Gravando...", flush=True)
    audio = sd.rec(int(SEGUNDOS_GRAVACAO * SAMPLE_RATE), samplerate=SAMPLE_RATE, channels=1, dtype='float32')
    sd.wait()
    audio = np.concatenate([trecho, audio]).flatten()

    result = model.transcribe(audio,
        language="pt",
        fp16=False,
        initial_prompt="jarvis youtube google calculadora spotify discord valorant wallpaper desligar reiniciar")

    texto = result["text"].strip().lower()
    print("Ouvido: " + texto, flush=True)

    if any(cmd in texto for cmd in COMANDOS):
        print(texto, flush=True)
    
    print("Ouvindo...", flush=True)