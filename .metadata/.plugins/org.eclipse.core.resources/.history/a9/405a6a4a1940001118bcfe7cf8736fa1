import sounddevice as sd
import numpy as np
import sys
import unicodedata
import re
import os
import warnings
from faster_whisper import WhisperModel

# ==============================
# LIMPAR AVISOS
# ==============================
os.environ["HF_HUB_DISABLE_SYMLINKS_WARNING"] = "1"
warnings.filterwarnings("ignore")
sys.stdout.reconfigure(encoding='utf-8')

# ==============================
# CONFIGURAÇÕES
# ==============================
SAMPLE_RATE = 16000
CHUNK = 0.5

LIMIAR_VOZ = 0.03        # mais alto (anti-ruído)
SILENCIO_LIMIAR = 0.015
LIMIAR_RUIDO = 0.02

# ⚠️ se necessário, defina manualmente:
# sd.default.device = 1

# ==============================
# MODELO (RÁPIDO)
# ==============================
model = WhisperModel("base", compute_type="int8")

# ==============================
# COMANDOS
# ==============================
COMANDOS = [
    "youtube", "google", "calculadora", "spotify",
    "discord", "valorant", "parede",
    "desligar", "reiniciar", "cancelar",
    "parar", "jarvis", "chat"
]

FRASES_LIXO = [
    "ouvindo", "legendas", "musica", "som de fundo"
]

# ==============================
# FUNÇÕES
# ==============================
def normalizar(txt):
    return unicodedata.normalize('NFKD', txt)\
        .encode('ascii', 'ignore')\
        .decode('ascii')\
        .lower()

def contem_palavra(frase, palavra):
    return re.search(r'\b' + re.escape(palavra) + r'\b', frase)

def detectar_voz():
    while True:
        audio = sd.rec(int(CHUNK * SAMPLE_RATE),
                       samplerate=SAMPLE_RATE,
                       channels=1,
                       dtype='float32')
        sd.wait()

        volume = np.abs(audio).mean()

        if volume >= LIMIAR_VOZ:
            return audio

def gravar_ate_silencio(primeiro_trecho):
    buffer = [primeiro_trecho]

    while True:
        trecho = sd.rec(int(CHUNK * SAMPLE_RATE),
                        samplerate=SAMPLE_RATE,
                        channels=1,
                        dtype='float32')
        sd.wait()

        buffer.append(trecho)

        volume = np.abs(trecho).mean()

        if volume < SILENCIO_LIMIAR:
            break

    return np.concatenate(buffer).flatten()

def transcrever(audio):
    segments, _ = model.transcribe(audio, language="pt")

    textos = []
    for seg in segments:
        # ignora baixa confiança (anti-alucinação)
        if seg.avg_logprob < -1.0:
            continue
        textos.append(seg.text)

    texto = " ".join(textos)
    return normalizar(texto.strip())

# ==============================
# LOOP PRINCIPAL
# ==============================
print("Jarvis ouvindo...", flush=True)

while True:
    try:
        # 1. Detecta voz
        primeiro = detectar_voz()

        # 2. Grava até silêncio
        audio = gravar_ate_silencio(primeiro)

        # 3. Filtro de ruído
        if np.abs(audio).mean() < LIMIAR_RUIDO:
            continue

        # 4. Duração mínima (evita cortes/ruído)
        if len(audio) < SAMPLE_RATE * 1.5:
            continue

        # 5. Transcreve
        texto = transcrever(audio)

        if len(texto) < 3:
            continue

        # 6. Ignora frases lixo do Whisper
        if any(frase in texto for frase in FRASES_LIXO):
            continue

        # 7. Estrutura mínima (evita "jarvis ouvindo")
        palavras = texto.split()
        if len(palavras) < 2:
            continue

        # 8. Wake word obrigatório
        if not contem_palavra(texto, "jarvis"):
            continue

        # 9. Verifica comandos
        if any(contem_palavra(texto, cmd) for cmd in COMANDOS):
            print(texto, flush=True)

    except Exception as e:
        print("Erro:", e)