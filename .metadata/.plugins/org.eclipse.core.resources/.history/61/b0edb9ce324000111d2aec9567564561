public class Main {

    static Process processoFala = null;
    static volatile boolean parar = false;

    // IA local (Ollama)
    public static String perguntarIA(String pergunta) throws Exception {

        URL url = new URL("http://localhost:11434/api/generate");
        HttpURLConnection con = (HttpURLConnection) url.openConnection();

        con.setRequestMethod("POST");
        con.setRequestProperty("Content-Type", "application/json");
        con.setDoOutput(true);

        pergunta = pergunta.trim();

        con.setConnectTimeout(5000);
        con.setReadTimeout(60000);

        // JSON correto
        JSONObject jsonEnvio = new JSONObject();
        jsonEnvio.put("model", "mistral");
        jsonEnvio.put("prompt", "Responda curto: " + pergunta);
        jsonEnvio.put("stream", false);

        String body = jsonEnvio.toString();

        try (OutputStream os = con.getOutputStream()) {
            os.write(body.getBytes("utf-8"));
        }

        BufferedReader br = new BufferedReader(
            new InputStreamReader(con.getInputStream(), "utf-8"));

        StringBuilder resposta = new StringBuilder();
        String linha;

        while ((linha = br.readLine()) != null) {
            resposta.append(linha);
        }

        String jsonResposta = resposta.toString();
        System.out.println("JSON: " + jsonResposta);

        JSONObject obj = new JSONObject(jsonResposta);

        if (obj.has("response")) {
            return obj.getString("response")
                      .replace("\\n", " ")
                      .trim();
        } else if (obj.has("error")) {
            return "Erro: " + obj.getString("error");
        } else {
            return "Resposta inválida da IA";
        }
    }

    public static void falar(String texto) throws Exception {

        parar = false;
        texto = texto.replace("'", "");

        String script = "Add-Type -AssemblyName System.Speech; " +
            "$s = New-Object System.Speech.Synthesis.SpeechSynthesizer; " +
            "$s.SelectVoice('Microsoft Maria Desktop'); " +
            "$s.Speak('" + texto + "');";

        processoFala = new ProcessBuilder("powershell", "-Command", script).start();

        while (processoFala.isAlive()) {
            if (parar) {
                processoFala.destroyForcibly();
                break;
            }
            Thread.sleep(100);
        }
    }

    public static void pararFala() {
        parar = true;

        if (processoFala != null && processoFala.isAlive()) {
            processoFala.destroyForcibly();
            System.out.println("Fala interrompida.");
        }
    }

